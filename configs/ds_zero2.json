{
  "_comment": "DeepSpeed ZeRO-2 — recommended for 8x A6000 with this model size.",
  "_comment2": "Partitions optimizer states + gradients. All params stay on each GPU.",

  "train_micro_batch_size_per_gpu": 4,
  "gradient_accumulation_steps": 2,
  "gradient_clipping": 1.0,
  "steps_per_print": 20,

  "zero_optimization": {
    "stage": 2,
    "allgather_partitions": true,
    "allgather_bucket_size": 500000000,
    "overlap_comm": true,
    "reduce_scatter": true,
    "reduce_bucket_size": 500000000,
    "contiguous_gradients": true
  },

  "bf16": {
    "enabled": true
  },

  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": 1e-4,
      "betas": [0.9, 0.999],
      "eps": 1e-8,
      "weight_decay": 1e-4
    }
  },

  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "warmup_min_lr": 1e-6,
      "warmup_max_lr": 1e-4,
      "warmup_num_steps": 100,
      "total_num_steps": 5000
    }
  },

  "activation_checkpointing": {
    "partition_activations": false,
    "contiguous_memory_optimization": true,
    "number_checkpoints": 4
  },

  "wall_clock_breakdown": false,
  "comms_logger": {
    "enabled": false
  }
}
